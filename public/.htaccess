# DK CourtFest SPA — Apache / LiteSpeed (Hostinger)
Options -MultiViews

# Client-side routing: send unknown paths to index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Long-cache fingerprinted assets
  <FilesMatch "\.(js|css|svg|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Never cache the shell / service worker so updates roll out immediately
  <FilesMatch "(^index\.html$|sw\.js$|workbox-.*\.js$|registerSW\.js$|manifest\.webmanifest$)">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
